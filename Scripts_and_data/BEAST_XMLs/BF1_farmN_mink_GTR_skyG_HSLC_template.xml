	<!-- The general time reversible (GTR) substitution model                    -->
	<gtrModel id="gtr">
		<frequencies>
			<frequencyModel dataType="nucleotide">
				<frequencies>
					<parameter id="frequencies" value="0.25 0.25 0.25 0.25"/>
				</frequencies>
			</frequencyModel>
		</frequencies>
		<rates>
			<parameter id="gtr.rates" dimension="6" value="1.0" lower="0.0"/>
		</rates>
	</gtrModel>

	<!-- site model                                                              -->
	<siteModel id="siteModel">
		<substitutionModel>
			<gtrModel idref="gtr"/>
		</substitutionModel>
		<gammaShape gammaCategories="4">
			<parameter id="alpha" value="0.5" lower="0.0"/>
		</gammaShape>
	</siteModel>

	<!--                                                                         -->
	<statistic id="mu" name="mu">
		<siteModel idref="siteModel"/>
	</statistic>
	

	<!-- Likelihood for tree given sequence data                                 -->
	
	<treeDataLikelihood id="default.treeLikelihood" useAmbiguities="false" usePreOrder="true" scalingScheme="always" delayScaling="false">
		<partition>
			<patterns idref="patterns"/>
			<siteModel idref="siteModel"/>
		</partition>
		<treeModel idref="treeModel"/>
		<localClockModel idref="default.branchRates"/>
	</treeDataLikelihood>
	
	<distributionLikelihood id="interceptPrior">
		<data>
			<parameter idref="intercept"/>
		</data>
		<distribution>
			<normalDistributionModel meanInRealSpace="true">
				<mean>
					<parameter value="-10.0" lower="0.0"/>
				</mean>
				<stdev>
					<parameter value="10.0" lower="0.0"/>
				</stdev>
			</normalDistributionModel>
		</distribution>
	</distributionLikelihood>

	<distributionLikelihood id="mink.fixedEffectsPrior">
		<data>
			<parameter idref="mink.coefficient"/>
		</data>
		<distribution>
			<normalDistributionModel meanInRealSpace="true">
				<mean>
					<parameter value="0.0"/>
				</mean>
				<stdev>
					<parameter id="betweenGroupStd1" value="2.0" lower="0.0"/>
				</stdev>
			</normalDistributionModel>
		</distribution>
	</distributionLikelihood>


	<!-- Define operators                                                        -->
	<operators id="operators" optimizationSchedule="log">
		<upDownOperator scaleFactor="0.75" weight="2">
			<up>
				<parameter idref = "intercept"/>
				<parameter idref="treeModel.rootHeight"/>
			</up>
			<down>
				<parameter idref="skygrid.logPopSize"/>
			</down>
		</upDownOperator>
		
        <randomWalkOperator windowSize="0.5" weight="2">
            <parameter idref="intercept"/>
        </randomWalkOperator>
		<randomWalkOperator windowSize="1.0" weight="5">
			<parameter idref = "mink.coefficient"/>
		</randomWalkOperator>
	

		<deltaExchange delta="0.01" weight="1">
			<parameter idref="gtr.rates"/>
		</deltaExchange>
		<deltaExchange delta="0.01" weight="1">
			<parameter idref="frequencies"/>
		</deltaExchange>
		<scaleOperator scaleFactor="0.75" weight="1">
			<parameter idref="alpha"/>
		</scaleOperator>

		<subtreeSlide size="1.0" gaussian="true" weight="30">
			<treeModel idref="treeModel"/>
		</subtreeSlide>
		<narrowExchange weight="30">
			<treeModel idref="treeModel"/>
		</narrowExchange>
		<wideExchange weight="3">
			<treeModel idref="treeModel"/>
		</wideExchange>
		<wilsonBalding weight="3">
			<treeModel idref="treeModel"/>
		</wilsonBalding>
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="treeModel.rootHeight"/>
		</scaleOperator>
		<uniformOperator weight="30">
			<parameter idref="treeModel.internalNodeHeights"/>
		</uniformOperator>

		<hamiltonianMonteCarloOperator weight="3" nSteps="50" stepSize="1E-2" instabilityHandler="reject"
						mode="vanilla" autoOptimize="true"
			gradientCheckCount="10000"
			gradientCheckTolerance="0.5"
			preconditioning="diagonal"
			preconditioningUpdateFrequency="100"
			>
			<compoundGradient idref="full.skygrid.gradient"/>
			<compoundParameter idref="skygrid.parameters"/>
			<signTransform start="1" end="1">
				<compoundParameter idref="skygrid.parameters"/>
			</signTransform>
		</hamiltonianMonteCarloOperator>
		<gmrfGridBlockUpdateOperator scaleFactor="1.0" weight="1">
			<gmrfSkyrideLikelihood idref="skygrid"/>
		</gmrfGridBlockUpdateOperator>
		<scaleOperator scaleFactor="0.1" weight="2">
			<parameter idref="skygrid.precision"/>
		</scaleOperator>

		</operators>
	

	<!-- Define MCMC                                                             -->
	<mcmc id="mcmc" chainLength="100000000" autoOptimize="true">
		<joint id="joint">
			<prior id="prior">
				<booleanLikelihood>
					<monophylyStatistic idref="monophyly(farmN-mink)"/>
				</booleanLikelihood>
				<dirichletPrior alpha="1.0" sumsTo="6.0">
					<parameter idref="gtr.rates"/>
				</dirichletPrior>
				<dirichletPrior alpha="1.0" sumsTo="1.0">
					<parameter idref="frequencies"/>
				</dirichletPrior>
				<exponentialPrior mean="0.5" offset="0.0">
					<parameter idref="alpha"/>
				</exponentialPrior>
				<distributionLikelihood idref="interceptPrior"/>
				<distributionLikelihood idref="mink.fixedEffectsPrior"/>

				<gammaPrior idref="skygrid.precision.prior"/>
				<gmrfSkyGridLikelihood idref="skygrid"/>

				<localClockModel idref="default.branchRates"/>
				
			</prior>
			<likelihood id="likelihood">
				<treeDataLikelihood idref="default.treeLikelihood"/>
			</likelihood>
		</joint>
		<operators idref="operators"/>


		<!-- write log to screen                                                     -->
		<log id="screenLog" logEvery="10000">
			<column label="Joint" dp="4" width="12">
				<joint idref="joint"/>
			</column>
			<column label="Prior" dp="4" width="12">
				<prior idref="prior"/>
			</column>
			<column label="Likelihood" dp="4" width="12">
				<likelihood idref="likelihood"/>
			</column>
			<column label="age(root)" sf="6" width="12">
				<tmrcaStatistic idref="age(root)"/>
			</column>
			<column label="intercept" sf="6" width="12">
				<parameter idref = "intercept"/>
			</column>
			<column label="mink.coefficient" sf="6" width="12">
				<parameter idref="mink.coefficient"/>
			</column>
			<column label="clock.rates.scale" sf="6" width="12">
				<parameter idref="clock.rates.scale"/>
			</column>
		</log>


		<!-- write log to file                                                       -->
		<log id="fileLog" logEvery="10000" fileName="BF1_farmN_GTR_skyG_HSLC.log" overwrite="false">
			<joint idref="joint"/>
			<prior idref="prior"/>
			<likelihood idref="likelihood"/>
			<parameter idref="treeModel.rootHeight"/>
			<tmrcaStatistic idref="age(root)"/>
			<treeLengthStatistic idref="treeLength"/>
			<tmrcaStatistic idref="tmrca(farmN-mink)"/>
			<tmrcaStatistic idref="age(farmN-mink)"/>
			<parameter idref="skygrid.precision"/>
			<parameter idref="skygrid.logPopSize"/>
			<parameter idref="skygrid.cutOff"/>
			<parameter idref="gtr.rates"/>
			<parameter idref="frequencies"/>
			<parameter idref="alpha"/>

			<parameter idref="fixedEffects"/>
			<exponentialStatistic id="mink.rate" name="mink.rate">
				<sumStatistic elementwise="true">
	   				<compoundParameter idref="fixedEffects"/> 
				</sumStatistic>
			</exponentialStatistic>
			<exponentialStatistic id="rate" name="rate">
				<parameter idref = "intercept"/>
			</exponentialStatistic>
	<!--		
			<parameter idref="ucld.mean"/>
			<parameter idref="ucld.stdev"/>
			<rateStatistic idref="meanRate"/>
			<rateStatistic idref="coefficientOfVariation"/>
			<rateCovarianceStatistic idref="covariance"/>
	-->
			<treeDataLikelihood idref="default.treeLikelihood"/>
	<!--
			<discretizedBranchRates idref="branchRates"/>
	-->
			<localClockModel idref="default.branchRates"/>
	
			<gmrfSkyGridLikelihood idref="skygrid"/>
		</log>


		<!-- write tree log to file                                                  -->
		<logTree id="treeFileLog" logEvery="10000" nexusFormat="true" fileName="BF1_farmN_GTR_skyG_HSLC.trees" sortTranslationTable="true">
		<treeModel idref="treeModel"/>
				<trait name="rate" tag="default.rate">
				<arbitraryBranchRates idref="default.branchRates"/>
			</trait>
			<joint idref="joint"/>
		</logTree>
	</mcmc>
	
	<report>
		<property name="timer">
			<mcmc idref="mcmc"/>
		</property>
	</report>
	
</beast>
