	<!-- Generate a tree model                                                   -->
	<treeModel id="treeModel">
		<tree idref="startingTree"/>
		<rootHeight>
			<parameter id="treeModel.rootHeight"/>
		</rootHeight>
		<nodeHeights internalNodes="true">
			<parameter id="treeModel.internalNodeHeights"/>
		</nodeHeights>
		<nodeHeights internalNodes="true" rootNode="true">
			<parameter id="treeModel.allInternalNodeHeights"/>
		</nodeHeights>
	</treeModel>

	<!-- Statistic for sum of the branch lengths of the tree (tree length)       -->
	<treeLengthStatistic id="treeLength">
		<treeModel idref="treeModel"/>
	</treeLengthStatistic>

	<!-- Statistic for time of most recent common ancestor of tree               -->
	<tmrcaStatistic id="age(root)" absolute="true">
		<treeModel idref="treeModel"/>
	</tmrcaStatistic>
	

	<!-- Taxon Sets                                                              -->
	
	<tmrcaStatistic id="tmrca(farmN-mink)" absolute="false" includeStem="false">
		<mrca>
			<taxa idref="farmN-mink"/>
		</mrca>
		<treeModel idref="treeModel"/>
	</tmrcaStatistic>
	<tmrcaStatistic id="age(farmN-mink)" absolute="true" includeStem="false">
		<mrca>
			<taxa idref="farmN-mink"/>
		</mrca>
		<treeModel idref="treeModel"/>
	</tmrcaStatistic>
	<monophylyStatistic id="monophyly(farmN-mink)">
		<mrca>
			<taxa idref="farmN-mink"/>
		</mrca>
		<treeModel idref="treeModel"/>
	</monophylyStatistic>
	

	<!-- Generate a gmrfSkyGridLikelihood for the Bayesian SkyGrid process       -->
	<gmrfSkyGridLikelihood id="skygrid">
		<populationSizes>

			<!-- skygrid.logPopSize is in log units unlike other popSize                 -->
			<parameter id="skygrid.logPopSize" dimension="50" value="1.0"/>
		</populationSizes>
		<precisionParameter>
			<parameter id="skygrid.precision" value="0.1" lower="0.0"/>
		</precisionParameter>
		<numGridPoints>
			<parameter id="skygrid.numGridPoints" value="49.0"/>
		</numGridPoints>
		<cutOff>
			<parameter id="skygrid.cutOff" value="2.0"/>
		</cutOff>
		<populationTree>
			<treeModel idref="treeModel"/>
		</populationTree>
	</gmrfSkyGridLikelihood>

	<compoundParameter id="skygrid.parameters">
		<parameter idref="skygrid.precision"/>
		<parameter idref="skygrid.logPopSize"/>
	</compoundParameter>

	<gmrfSkyrideGradient id="gmrfGradientPop" wrtParameter="logPopulationSizes">
		<gmrfSkyGridLikelihood idref="skygrid"/>
	</gmrfSkyrideGradient>
<!--

-->

<gmrfSkyrideGradient id="gmrfGradientPrec" wrtParameter="precision">
		<gmrfSkyGridLikelihood idref="skygrid"/>
	</gmrfSkyrideGradient>

	<report>
		<gmrfSkyrideGradient idref="gmrfGradientPrec"/>
	</report>

	<gammaPrior id="skygrid.precision.prior" shape="0.001" scale="1000" offset="0.0">
		<parameter idref="skygrid.precision"/>
	</gammaPrior>

	<jointGradient id="joint.skygrid.precision">
		<gmrfSkyrideGradient idref="gmrfGradientPrec"/>
		<gradient>
			<gammaPrior idref="skygrid.precision.prior"/>
			<parameter idref="skygrid.precision"/>
		</gradient>
	</jointGradient>

	<compoundGradient id="full.skygrid.gradient">
		<jointGradient idref="joint.skygrid.precision"/>
		<gmrfSkyrideGradient idref="gmrfGradientPop"/>
		<!-- <compoundParameter idref="skygrid.parameters"/> -->
	</compoundGradient>

	<report>
		<compoundGradient idref="full.skygrid.gradient"/>
	</report>

	<compoundParameter id="fixedEffects">
		<parameter id = "intercept" value="-7.2"/>
		<parameter id = "mink.coefficient" value="0.5"/>
