	set scaleBar.isShown=true;
	set scaleBar.lineWidth=1.0;
	set scaleBar.scaleRange=0.0;
	set tipLabels.colorAttribute="WHO_Label";
	set tipLabels.displayAttribute="Names";
	set tipLabels.fontName="sansserif";
